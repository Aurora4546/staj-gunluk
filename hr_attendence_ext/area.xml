<odoo>
    <data>
        <record id="hr_attendance_area_type_form_view" model="ir.ui.view">
            <field name="name">Area Types</field>
            <field name="model">hr.attendance.area.type</field>
            <field name="arch" type="xml">
                <form string="Area Type Form">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="toggle_active" type="object" groups="hr_attendance_ext.group_attendance_one"
                                    class="oe_stat_button" icon="fa-archive">
                                <field name="active" widget="boolean_button"
                                       options='{"terminology": "archive"}'/>
                            </button>
                        </div>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="hr_attendance_area_type_list_view" model="ir.ui.view">
            <field name="name">Area Types</field>
            <field name="model">hr.attendance.area.type</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="hr_attendance_area_form_view" model="ir.ui.view">
            <field name="name">Areas</field>
            <field name="model">hr.attendance.area</field>
            <field name="arch" type="xml">
                <form string="Area Form">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="toggle_active" type="object" groups="hr_attendance_ext.group_attendance_one"
                                    class="oe_stat_button" icon="fa-archive">
                                <field name="active" widget="boolean_button"
                                       options='{"terminology": "archive"}'/>
                            </button>
<!--                            <button name="sync_area_auth" type="object" groups="hr_attendance_ext.group_attendance_one,-->
<!--                                                                            hr_attendance_ext.group_attendance_three"-->
<!--                                    class="oe_stat_button" icon="fa-braille">-->
<!--                                Sync Auths-->
<!--                            </button>-->
                        </div>
                        <group>
                            <group>
                                <field name="id" invisible="1"/>
                                <field name="name"/>
                                <field name="location_id" options="{'no_create': True, 'no_open': True,'no_create_edit':True,'no_quick_create': True,}"/>
                            </group>
                            <group>
                                <field name="is_common_area"/>
                                <field name="area_type_id" invisible="1"/>
                                <field name="building_id" context="{'location_id':location_id,'active_id':id}"
                                options="{'no_create': True, 'no_open': True,'no_create_edit':True,'no_quick_create': True,}"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Zones">
                                <field name="zone_ids"/>
                            </page>
                            <page string="Auths">
                                <field name="auth_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="hr_attendance_area_list_view" model="ir.ui.view">
            <field name="name">Area List</field>
            <field name="model">hr.attendance.area</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="location_id" />
                    <field name="area_type_id" invisible="1"/>
                    <field name="is_common_area"/>
                    <field name="building_id"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>