<odoo>

    <record id="hr_attendance_card_auth_form_view" model="ir.ui.view">
        <field name="name">Cards Authorization</field>
        <field name="model">hr.attendance.card.authorization</field>
        <field name="arch" type="xml">
            <form string="Card Authorization Form">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" groups="hr_attendance_ext.group_attendance_one"
                                class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <group>
                        <group>
                                <field name="card_id"/>
                                <field name="location_id" required="1"/>
                                <field name="area_id" domain="[('location_id','in',location_id)]"/>
                                <field name="is_building" invisible="1"/>
                            </group>
                            <group>
                                <field name="building_id"
                                       attrs="{'invisible':[('is_building','=',False)]}"
                                        domain="[('area_id','in',area_id)]"/>
                                <field name="floor_id"
                                       attrs="{'invisible':[('is_building','=',False)]}"/>
                                <field name="zone_id"
                                   domain="['|',('area_id','in',area_id),('floor_id','in',floor_id)]"/>
                            </group>
                    </group>
                    <separator string="Terminals to Auth" />
                    <field name="terminal_ids" />
                     <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread" options='{"thread_level": 1}'/>
                     </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_attendance_card_auth_form_view_for_employee" model="ir.ui.view">
        <field name="name">Card Authorizations Employee</field>
        <field name="model">hr.attendance.card.authorization</field>
        <field name="arch" type="xml">
            <form string="Card Authorization Form Employee" create="false" edit="false">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" groups="hr_attendance_ext.group_attendance_one"
                                class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <group>
                        <group readonly="1">
                                <field name="card_id" readonly="1" options="{'no_create': True, 'no_open': True,'no_create_edit':True,'no_quick_create': True}"/>
                                <field name="location_id" required="1" readonly="1">
                                    <tree open="false">
                                        <field name="company_id"/>
                                        <field name="name"/>
                                        <field name="address"/>
                                        <field name="phone"/>
                                    </tree>
                                </field>
                                <field name="area_id" domain="[('location_id','in',location_id)]" readonly="1">
                                    <tree open="false">
                                        <field name="name"/>
                                        <field name="location_id"/>
                                        <field name="is_common_area"/>
                                        <field name="building_id"/>
                                    </tree>
                                </field>
                                <field name="is_building" invisible="1"/>
                            </group>
                            <group>
                                <field name="employee_id" options="{'no_create': True, 'no_open': True,'no_create_edit':True,'no_quick_create': True}" readonly="1"/>
                                <field name="building_id" readonly="1"
                                       attrs="{'invisible':[('is_building','=',False)]}"
                                        domain="[('area_id','in',area_id)]"/>
                                <field name="floor_id" readonly="1"
                                       attrs="{'invisible':[('is_building','=',False)]}"/>
                                <field name="zone_id" readonly="1"
                                   domain="['|',('area_id','in',area_id),('floor_id','in',floor_id)]">
                                    <tree open="false">
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="zone_type_id"/>
                                        <field name="area_id"/>
                                        <field name="floor_id"/>
                                    </tree>
                                </field>
                            </group>
                    </group>
                    <separator string="Terminals to Auth" />
                    <field name="terminal_ids" readonly="1">
                        <tree open="false">
                            <field name="device_id"/>
                            <field name="terminal_type_id"/>
                            <field name="terminal_no"/>
                            <field name="area_id"/>
                            <field name="building_id"/>
                            <field name="floor_id"/>
                            <field name="zone_id"/>
                            <field name="area_detail"/>
                        </tree>
                    </field>
                     <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread" options='{"thread_level": 1}'/>
                     </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_attendance_card_auth_list_view" model="ir.ui.view">
        <field name="name">Card Authorization List</field>
        <field name="model">hr.attendance.card.authorization</field>
        <field name="arch" type="xml">
            <tree>
                <field name="card_id" groups="hr_attendance_ext.group_attendance_one"/>
                <field name="employee_id"/>
                <field name="employee_department"/>
                <field name="location_id" required="1"/>
                <field name="area_id"/>
                <field name="is_building" invisible="1"/>
                <field name="building_id" attrs="{'invisible':[('is_building','=',False)]}"/>
                <field name="floor_id"
                       attrs="{'invisible':[('building_id','=',False)]}"/>
                <field name="zone_id"/>
            </tree>
        </field>
    </record>
</odoo>