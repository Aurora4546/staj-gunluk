<odoo>
    <data>
        <record id="view_hr_attendance_card_search" model="ir.ui.view">
            <field name="name">hr.attendance.card search</field>
            <field name="model">hr.attendance.card</field>
            <field name="arch" type="xml">
                <search string="Search Request">
                    <filter string="All" name="active" domain="['|',('active','=', True),('active','=', False)]"/>
                    <filter string="Active" name="active" domain="[('active','=',True)]"/>
                    <filter string="Archived" name="active" domain="[('active','=',False)]"/>
                    <filter string="Temporary" name="temporary" domain="[('temporary','=',True)]"/>
                    <field name="card_no" string="Tüm Alanlar"
                           filter_domain="['|','|','|',('card_no','ilike',self),
                           ('card_type','ilike',self),
                           ('card_state','ilike',self),
                           ('employee_id','ilike',self)]"/>
                    <field name="card_no"/>
                    <field name="card_type"/>
                    <field name="card_state"/>
                    <field name="employee_id"/>
                    <field name="employee_personel_id"/>
                    <field name="employee_first_name"/>
                    <field name="employee_last_name"/>
                    <field name="unlink_reason"/>
                    <field name="unlink_uid"/>

                    <!--                    <field name="visitor_id"/>-->
                    <!--                    <filter name="needs_review" string="Needs my Review"-->
                    <!--                            domain="[('reviewer_ids','in',uid), ('state', 'not in', ['approved', 'rejected','draft'])]"-->
                    <!--                            help="My requests to review"/>-->
                    <group expand="0" string="Grupla">
                        <filter string="Pasive Alma Sebebi" name="group_unlink_reason" domain="[]"
                                context="{'group_by':'unlink_reason'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record id="view_hr_attendance_card_authorization_search" model="ir.ui.view">
            <field name="name">hr.attendance.card.authorization search</field>
            <field name="model">hr.attendance.card.authorization</field>
            <field name="arch" type="xml">
                <search string="Search Request">
                    <field name="card_id" string="Tüm Alanlar"
                           filter_domain="['|',('card_id.card_no','ilike',self),('employee_id','ilike',self)]"/>
                    <separator/>
                    <filter string="Passive" name="active" domain="[('active','=',False)]"/>
                </search>
            </field>
        </record>

        <record id="view_hr_attendance_area_search" model="ir.ui.view">
            <field name="name">hr.attendance.area search</field>
            <field name="model">hr.attendance.area</field>
            <field name="arch" type="xml">
                <search string="Search Request">
                    <filter string="All" name="active" domain="[('active','in',[True, False])]"/>
                    <filter string="Archived" name="active" domain="[('active','=',False)]"/>
                    <field name="name"/>
                    <field name="location_id"/>
                    <field name="area_type_id"/>
                    <field name="is_common_area"/>
                    <field name="building_id"/>
                    <field name="floor_ids"/>
                </search>
            </field>
        </record>

        <record id="view_hr_attendance_terminal_search" model="ir.ui.view">
            <field name="name">hr.attendance.terminal search</field>
            <field name="model">hr.attendance.terminal</field>
            <field name="arch" type="xml">
                <search string="Search Request">
                    <field name="device_id"/>
                    <field name="terminal_type_id"/>
                    <field name="terminal_no"/>
                    <field name="ip_no"/>
                    <field name="area_detail"/>
                    <field name="zone_id"/>
                    <field name="area_id"/>
                    <field name="floor_id"/>
                    <field name="building_id"/>
                    <!--                    <field name="visitor_id"/>-->
                    <!--                    <filter name="needs_review" string="Needs my Review"-->
                    <!--                            domain="[('reviewer_ids','in',uid), ('state', 'not in', ['approved', 'rejected','draft'])]"-->
                    <!--                            help="My requests to review"/>-->
                    <separator/>
                    <filter string="Passive" name="active" domain="[('active','=',False)]"/>
                </search>
            </field>
        </record>

        <record id="view_hr_attendance_zone_search" model="ir.ui.view">
            <field name="name">hr.attendance.zone search</field>
            <field name="model">hr.attendance.zone</field>
            <field name="arch" type="xml">
                <search string="Search Request">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="zone_type_id"/>
                    <field name="zone_tag_ids"/>
                    <field name="area_id"/>
                    <field name="floor_id"/>
                    <field name="building_id"/>
                    <field name="zone_auth_owner"/>
                    <!--                    <field name="visitor_id"/>-->
                    <!--                    <filter name="needs_review" string="Needs my Review"-->
                    <!--                            domain="[('reviewer_ids','in',uid), ('state', 'not in', ['approved', 'rejected','draft'])]"-->
                    <!--                            help="My requests to review"/>-->
                    <separator/>
                    <filter string="Passive" name="active" domain="[('active','=',False)]"/>
                </search>
            </field>
        </record>

        <record id="view_hr_attendance_auth_request_search" model="ir.ui.view">
            <field name="name">hr.attendance.card.auth.request search</field>
            <field name="model">hr.attendance.card.auth.request</field>
            <field name="arch" type="xml">
                <search string="Search Request">
                    <field name="zone_id"/>
                    <field name="zone_auth_owner"/>
                    <field name="zone_users"/>
                    <field name="reason"/>
                    <field name="state"/>
                    <!--                    <field name="visitor_id"/>-->
                    <!--                    <filter name="needs_review" string="Needs my Review"-->
                    <!--                            domain="[('reviewer_ids','in',uid), ('state', 'not in', ['approved', 'rejected','draft'])]"-->
                    <!--                            help="My requests to review"/>-->
                </search>
