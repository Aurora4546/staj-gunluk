        </record>

        <record id="hr_attendance_employee_attendance_filter" model="ir.ui.view">
            <field name="name">hr.employee card kanban</field>
            <field name="model">hr.employee</field>
            <field name="arch" type="xml">
                <search string="Search Employee">
                    <field name="name" string="General Search"
                           filter_domain="['|','|','|','|',
                           ('card_ids.card_no','ilike',self),
                           ('personel_id','=',self),
                           ('name','ilike',self),
                           ('first_name','ilike',self),
                           ('last_name','ilike',self)]"/>
                    <field name="working_type"/>
                    <field name="card_ids"/>
                    <field name="personel_id"/>
                    <separator/>
                    <filter string="All" name="active" domain="[('active','in',[True, False])]"/>
                    <filter string="Passive" name="active" domain="[('active','=',False)]"/>
                    <filter string="Temporary Card Owners" name="temp_card_owners"
                            domain="[('card_ids.temporary','=',True)]"/>
                    <filter string="Card Inactive 10 Days" name="card_inactive_soon"
                            domain="[('card_ids.validity_expire_time','&lt;',datetime.datetime.now() + datetime.timedelta(days=10))]"/>
                    <filter string="Card Inactive This Month" name="card_inactive_this_month"
                            domain="[('card_ids.validity_expire_time','&lt;', (datetime.datetime.now().replace(day=28) + datetime.timedelta(days=4)).replace(day=1, hour=0, minute=0, second=0, microsecond=0))]"/>
                </search>
            </field>
        </record>

        <record id="view_hr_attendance_card_assignment_log_search" model="ir.ui.view">
            <field name="name">hr.attendance.card.assignment.log search</field>
            <field name="model">hr.attendance.card.assignment.log</field>
            <field name="arch" type="xml">
                <search string="Search Request">
                    <field name="card_id"/>
                    <field name="card_no" string="Kart Kimliği"
                           filter_domain="[('card_id.visitor_card_identity_number','ilike',self)]"/>
                    <field name="employee_id"/>
                    <field name="personal_id" string="Çalışan Tipi"
                           filter_domain="[('employee_id.working_type','ilike',self)]"/>
                    <field name="reason"/>
                    <field name="return_date"/>
                    <separator/>
                    <filter string="Not Returned" name="return_date" domain="[('card_id.assignment_log','=',False)]"/>

                    <filter string="Tusaş Çalışan" name="tusas_calisan_card"
                            domain="[('employee_id.working_type','=','taiEmployee')]"/>
                    <filter string="Çalışman" name="caliman_card"
                            domain="[('employee_id.working_type','=','theStudy')]"/>
                    <filter string="Stajyer" name="stayjer_card" domain="[('employee_id.working_type','=','trainee')]"/>
                    <filter string="Temsilci" name="temsilci_card"
                            domain="[('employee_id.working_type','=','representative')]"/>
                    <filter string="Firma Çalışanı" name="firma_calisani_card"
                            domain="[('employee_id.working_type','=','companyEmployee')]"/>

                </search>
            </field>
        </record>

