<odoo>
    <data>
        <record id="hr_attendance_fdw_settings_tree_view" model="ir.ui.view">
            <field name="name">FDW Settings</field>
            <field name="model">hr.attendance.fdw_settings</field>
            <field name="arch" type="xml">
                <tree delete="false">
                    <field name="name"/>
                    <field name="prefix"/>
                    <field name="suffix"/>
                    <field name="state"/>
                    <field name="model_objects"/>
                </tree>
            </field>
        </record>
        <record id="hr_attendance_fdw_settings_form_view" model="ir.ui.view">
            <field name="name">FDW Settings</field>
            <field name="model">hr.attendance.fdw_settings</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="create_models" type="object"
                                    groups="hr_attendance_ext.group_attendance_one,hr_attendance_ext.group_attendance_three"
                                    class="oe_stat_button" icon="fa-magic"
                                    string="Create Objects">
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="state"/>
                            </group>
                            <group>
                                <field name="prefix"/>
                                <field name="suffix"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Object to Copy">
                                <field name="model_objects">
                                    <tree>
                                        <field name="name"/>
                                        <field name="model"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>