<odoo>

    <record id="attendance_bulk_card_replacement_window" model='ir.actions.act_window'>
        <field name="name">Attendance Bulk Card Replacement</field>
        <field name="res_model">hr.attendance.bulk.card.replacement</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="domain">[('employee_id.card_ids', '!=', False),('employee_id.card_ids.active', '=', True)]</field>
        <field name="context">{'card_replacement':True}</field>
    </record>


    <record id="attendance_bulk_card_replacement_tree" model='ir.ui.view'>
        <field name="name">Attendance Bulk Card Replacement Tree</field>
        <field name="model">hr.attendance.bulk.card.replacement</field>
        <field name="arch" type="xml">
            <tree editable="top" create="false" decoration-muted="current_card_no == False" decoration-success="temp_card_no != False" decoration-danger="is_temporary == True">
<!--                <field name="employee_id" readonly="1" force_save="1"-->
<!--                       options="{'no_create': True, 'no_open': True,'no_create_edit': True,'no_quick_create': True}"/>-->
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="personel_id"/>
                <field name="working_type"/>
                <field name="department_id"
                       options="{'no_create': True, 'no_open': True,'no_create_edit': True,'no_quick_create': True}"/>
                <field name="current_card_no"/>
                <field name="is_temporary" invisible="1"/>
                <field name="new_card_no" />
                <field name="will_sync" string="İşlenecek" />
                <field name="temp_card_no" invisible="1"/>
                <button name="return_card_back" string="Return Card" type="object" class="btn btn-info" groups="base.group_no_one"
                        attrs="{'invisible': [('temp_card_no','=',False)]}"/>
            </tree>
        </field>
    </record>


    <record model="ir.ui.view" id="attendance_bulk_card_replacement_search_view">
        <field name="name">bulk_card_replacement_search</field>
        <field name="model">hr.attendance.bulk.card.replacement</field>
        <field name="arch" type="xml">
            <search>

                <field name="employee_id" string="General Search"
                       filter_domain="['|','|','|','|',('employee_id','ilike',self),('employee_id.personel_id','ilike',self),
                       ('employee_id.department_id','ilike',self),('employee_id.working_type','ilike',self),('employee_id.card_ids.card_no','ilike',self),]"/>
                <filter name="show_not_done" string="Those Who not Process" domain="[('temp_card_no', '=', False),('active', '=', True),('employee_id.card_ids', '!=', False)]" />
                <filter name="show_done" string="Those Who Process" domain="[('temp_card_no', '!=', False),('active', '=', False),('employee_id.card_ids', '!=', False)]" />
                <filter name="show_recorded" string="Yeni Kart No Girilmiş" domain="[('new_card_no', '!=', False),('employee_id.card_ids', '!=', False)]" />
<!--                <filter name="show_those_who_no_cards" string="Those Who No Card" domain="[('employee_id.card_ids', '=', False)]" />-->
            </search>
        </field>
    </record>

</odoo>