<odoo>


    <record id="hr_employee_bulk_operations_inherit_view" model="ir.ui.view">
        <field name="name">Employee Bulk Inherit</field>
        <field name="model">hr_employee_history.bulk_personal_id_update_wizard</field>
        <field name="inherit_id" ref="hr_employee_history.hr_employee_ext_bulk_personal_form"/>
        <field name="arch" type="xml">
            <xpath expr='//div[@name="button_box"]' position='replace'>
                    <div class="oe_button_box" name="button_box">
                            <button name="create_movement" type="object" groups="hr_employee_ext.group_hr_manager"
                                    class="oe_stat_button" icon="fa-file-excel-o" string="Create Movements"
                                   context="{'is_authorize_removed': is_authorize_removed}">
                            </button>
                        </div>
            </xpath>
            <xpath expr="//field[@name='excel_file']" position="before">
                    <field name="is_authorize_removed" attrs="{'invisible': [('movement_type','!=','3')]}" />

            </xpath>

        </field>
    </record>




</odoo>

