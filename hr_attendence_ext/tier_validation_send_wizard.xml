<odoo>

    <record id="tier_validation_send_wizard" model="ir.ui.view">
        <!--        <field name="name">Tier Validation Send Wizard</field>-->
        <field name="model">tier.validation.send.wizard</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Comment">

                <field name="auth_request_id" invisible="1"/>
                <style>
                    .zone_auth_flow {
                    -webkit-border-radius: 10px;
                    -moz-border-radius: 10px;
                    border-radius: 10px;
                    font-size:1.2em;
                    font-weight:400;
                    }
                </style>
                <h1 class="center" style="text-align:center;">Attention!</h1>
                <br />
                <div style="width:100%;height:100px;text-align:center;margin: auto;">

                    <div style="width:17%;height:70px;border:1px solid black;float:left;" class="zone_auth_flow">
                        <table style="width:100%;height:70px;text-align:center;">
                            <tr>
                                <td style="text-align:center">Talep</td>
                            </tr>
                        </table>
                    </div>
                    <div style="width:5%;height:70px;float:left;margin-left:2%;" class="zone_auth_flow">
                        <table style="width:100%;height:70px;text-align:center;">
                            <tr>
                                <td style="text-align:center">
                                    <p>
                                        <i class="fa fa-arrow-right fa-2x"><span> </span></i>
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div style="width:17%;height:70px;border:1px solid black;float:left;margin-left:2%;" class="zone_auth_flow">
                        <table style="width:100%;height:70px;text-align:center;">
                            <tr>
                                <td style="text-align:center">İlk Amir Onayı</td>
                            </tr>
                        </table>
                    </div>
                    <div style="width:5%;height:70px;float:left;margin-left:2%;" class="zone_auth_flow">
                        <table style="width:100%;height:70px;text-align:center;">
                            <tr>
                                <td style="text-align:center">
                                    <p>
                                        <i class="fa fa-arrow-right fa-2x"><span> </span></i>
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div style="width:17%;height:70px;border:1px solid black;float:left;margin-left:2%;" class="zone_auth_flow">
                        <table style="width:100%;height:70px;text-align:center;">
                            <tr>
                                <td style="text-align:center">Yetki Vermeye Yetkili Personel Onayı</td>
                            </tr>
                        </table>
                    </div>
                    <div style="width:5%;height:70px;float:left;margin-left:2%;" class="zone_auth_flow">
                        <table style="width:100%;height:70px;text-align:center;">
                            <tr>
                                <td style="text-align:center">
                                    <p>
                                        <i class="fa fa-arrow-right fa-2x"><span> </span></i>
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div style="width:17%;height:70px;border:1px solid black;float:left;margin-left:2%;" class="zone_auth_flow">
                        <table style="width:100%;height:70px;text-align:center;">
                            <tr>
                                <td style="text-align:center">Programlar ve Personel
                                    Güvenlik Şefliği
                                </td>
                            </tr>
                        </table>
                    </div>

                </div>
                <h4 class="center" style="text-align:center;color:red;">Not: Hassas bölge erişim yetkisi taleplerinde Programlar ve Personel Güvenlik Şefliği'ne onaya gitmeyecektir.</h4>
                <br/>
                <span>
                    Savunma Sanayii Güvenliği Mevzuatı gereği gizlilik dereceli çalışmaların yapıldığı Kontrollü
                    Bölgeler için Kişi Güvenlik Belgesi zorunluluğu bulunmaktadır.
                    <ul>
                        <li>Yetki Verilen Kişi, Kontrollü Bölgenin Çalışma Talimatını okumalıdır. Yetkisiz personel girişine
                    müsaade etmemelidir.</li>
                        <li>Kontrollü Bölge giriş çıkış kapılarını sürekli kapalı tutulmalıdır.</li>
                    </ul>
                    Yetki talebinde bulunan kişi, yetki talep edilen kişilere konu hakkında bilgilendirme yapması gerekmektedir.
                </span>

                <footer>
                    <table style="width:100%;">
                        <tr>
                            <td style="width:50%;text-align:center;">
                                <button name="action_send_request" string="I Approve" type="object"
                                        class="btn-success icon-2x" icon="fa-check"
                                        style="width:175px;height:90px;font-size:2em;"
                                />
                            </td>

                            <td style="width:50%;text-align:center;">
                                <button special="cancel" string="Cancel" class="btn-secondary fa-2x"
                                        style="width:175px;height:90px;font-size:2em;"/>
                            </td>
                        </tr>
                    </table>


                </footer>
            </form>
        </field>
    </record>

</odoo>