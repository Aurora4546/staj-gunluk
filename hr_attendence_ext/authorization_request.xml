    <record id="zone_auth_request_action" model="ir.actions.act_window">
        <field name="name">Zone Auth Request</field>
        <field name="res_model">hr.attendance.card.auth.request</field>
        <field name="view_mode">form</field>
        <field name="search_view_id" ref="zone_auth_request_filter"/>
        <field name="context">{"search_default_needs_review":1,
            'allow_bulk_save_send':True,
            'allow_bulk_validations':True,
            'hide_delete':True}
        </field>
        <field name="domain">['|','|','|',('zone_auth_owner.user_id', 'child_of', uid),
            ('zone_users.user_id', 'child_of',
            uid),('create_uid','=',uid),
            ('reviewer_ids','=',uid)]
        </field>
    </record>

