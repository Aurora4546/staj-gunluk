<odoo>
    <record id="card_auth_request_tree" model="ir.ui.view">
        <field name="name">ERP Role Requests</field>
        <field name="model">hr.attendance.card.auth.request</field>
        <!--            <field name="search_view_id" ref="role_request_filter"/>-->
        <field name="arch" type="xml">
            <tree delete="false" create="false">
                <field name="record_num"/>
                <field name="requester_image" widget="image" string=""/>
                <field name="create_uid"/>
                <field name="requester_personal_id"/>
                <field name="requester_department"/>
                <field name="zone_id"/>
                <field name="reason"/>
                <!--                <field name="zone_users"/>-->
                <!--                <field name="state"/>-->
                <field name="create_date"/>
                <!--                <field name="write_date"/>-->
            </tree>

        </field>
    </record>

    <record id="card_auth_request_form" model="ir.ui.view">
        <field name="name">ERP Role Request Form</field>
        <field name="model">hr.attendance.card.auth.request</field>
        <field name="arch" type="xml">
            <form>
                <style>
                    .o_form_button_save, .o_form_button_edit {
                    display:none;
                    }
                    .breadcrumb, .breadcrumb-item{
                    display:none !important;
                    text-indent: -9999px;
                    }
                </style>
                <header class="oe_read_only">


                    <field name="state" string="State" readonly="1" widget="statusbar"/>
                </header>
                <table style="width:100%;">
                    <tr>
                        <th style="text-align:center;">
                            <h1 style="font-size:green;">Operasyon Seçiniz</h1>
                        </th>
                    </tr>
                    <tr>
                        <td style="text-align:center;">
                            <h3>
                                <field style="font-size:green;" name="m_request" widget="radio"/>
                            </h3>
                        </td>

                    </tr>
                </table>

                <field name="security_check" invisible="1"/>
                <sheet>
                    <group>
                        <group style="width:65%;">
                            <field name="zone_id"
                                   options="{'no_create': True, 'no_open': True,'no_create_edit':True,'no_quick_create': True,}"/>
                        </group>
                        <group style="text-align:center;width:30%;" attrs="{'invisible': [('zone_id', '!=', False)]}">
                            <h1 style="color:red;">Bölge ve Kişi Seçiniz</h1>
                        </group>
                        <group style="text-align:right;width:30%;"
                               attrs="{'invisible': ['|',('zone_id', '=', False),('security_check', '=', False)]}">
                            <img src="/hr_attendance_ext/static/src/img/kontrollubolge.png" alt="Kontrollü Bölge"
                                 style="width:180px;height:129px;"/>
                        </group>
                        <group style="text-align:right;width:30%;"
                               attrs="{'invisible': ['|',('zone_id', '=', False),('security_check', '=', True)]}">
                            <img src="/hr_attendance_ext/static/src/img/hassasbolge.png" alt="Hassas Bölge"
                                 style="width:180px;height:129px;"/>
                        </group>
                    </group>
                    <group>
                        <field name="zone_auth_owner">
                            <tree>
                                <field name="name"/>
                                <field name="personel_id"/>
                                <field name="work_phone"/>
                                <field name="work_email"/>
                                <field name="department_id"/>
                            </tree>
                        </field>
                        <field name="zone_users">
                            <tree>
                                <field name="name"/>
                                <field name="personel_id"/>
                                <field name="work_phone"/>
                                <field name="work_email"/>
                                <field name="department_id"/>
                                <button name="delete_user_from_card_auth" type="object"
                                        groups="hr_attendance_ext.group_attendance_one" icon="fa-close"
                                        context="{'auth_id':parent.id}" invisible="context.get('hide_delete',False)"/>
                                <!--attrs="{'invisible':[(parent.state,'=','in_validation')]}"-->
                            </tree>
                        </field>
                    </group>
                    <group>
                        <field name="reason"/>
                    </group>


                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="card_auth_request_kanban">
        <field name="name">hr.attendance.card.auth.request.kanban</field>
        <field name="model">hr.attendance.card.auth.request</field>
        <field name="arch" type="xml">
            <kanban class="o_res_partner_kanban"
                    color="blue:can_review==true;red:state in ('rejected');green:state in ('approved');black:state=='draft'">
                <field name="id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{kanban_color(record.color.raw_value) + ' oe_kanban_global_click'}">
                            <div t-attf-class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary">
                                        <b>
                                            <field name="zone_id"/>
                                        </b>
                                    </div>
                                    <div style="font-size:11px;">
                                        <b>Users to Authenticate:</b>
                                    </div>
                                    <field name="zone_users" widget="many2many_tags"/>
                                    <p style="font-size:11px;">
                                        <b>Requested by:</b>
                                        <field name="create_uid"/>
                                    </p>
                                    <field name="can_review" invisible="1"/>
                                    <field name="state" invisible="1"/>
                                    <field name="color" invisible="1"/>
                                </div>
                            </div>
                            <field name="need_validation" groups="base.group_no_one" invisible="1"/>
                            <field name="validated" groups="base.group_no_one" invisible="1"/>
                            <field name="rejected" groups="base.group_no_one" invisible="1"/>
                            <field name="is_creator" groups="base.group_no_one" invisible="1"/>
                            <div
                                    role="alert"
                                    attrs="{'invisible': ['|', '|', '|',
                                                 ('validated', '=', True), ('state', 'not in', ['in_validation']),
                                                 ('rejected', '=', True)]}"
                                    style="margin-bottom:0px;">
                                <table style="width:100%">
                                    <tr style="width:100%">
                                        <td>
                                            <button name="validate_tier"
                                                    string="Validate"
                                                    attrs="{'invisible': [('can_review', '=', False)]}"
                                                    type="object"
                                                    class="btn oe_button btn-success"
                                                    style="width:80px;margin-left:40px">Validate
                                            </button>
                                        </td>
                                        <td style="align:right;text-align:right;float:right;">
                                            <button name="reject_tier"
                                                    string="Reject"
                                                    attrs="{'invisible': [('can_review', '=', False)]}"
                                                    type="object"
                                                    class="btn btn-icon btn-danger"
                                                    style="width:80px;margin-right:40px">Reject
                                            </button>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>

        </field>
    </record>
    <record id="card_auth_request_kanban_attr_inherit" model="ir.ui.view">
        <field name="name">hr.attendance.card.auth.request</field>
        <field name="model">hr.attendance.card.auth.request</field>
        <field name="inherit_id" ref="card_auth_request_kanban"/>
        <field name="arch" type="xml">
            <kanban position="attributes">
                <attribute name="disable_drag_drop_record">true</attribute>
                <attribute name="quick_create">false</attribute>
                <attribute name="group_create">false</attribute>
                <attribute name="group_edit">false</attribute>
                <attribute name="group_delete">false</attribute>
                <attribute name="archivable">false</attribute>
            </kanban>
        </field>
    </record>


    <record id="card_auth_request_form_inherit" model="ir.ui.view">
        <field name="name">Card Auth Request Validation</field>
        <field name="model">hr.attendance.card.auth.request</field>
        <field name="inherit_id" ref="card_auth_request_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <!--                <button name="request_validation"-->
                <!--                        class="btn-info"-->
                <!--                        string="Send Request"-->
                <!--                        attrs="{'invisible': ['|','|','|',('need_validation', '!=', True),('rejected','=',True),('state','not in',['draft']),('is_creator','=',False)]}"-->
                <!--                        type="object"-->
                <!--                />-->
                <button name="validate_tier"
                        string="Validate"
                        attrs="{'invisible': [('can_review', '=', False)]}"
                        type="object"
                        class="oe_inline oe_button standard-approve"
                        icon="fa-thumbs-up"/>
                <field name="can_open_model_admin" invisible="1"/>
                <button name="open_model_admin_wizard"
                        class="fa fa-random btn-outline-primary"
                        attrs="{'invisible': [('can_open_model_admin','=',False)]}"
                        string="Tier Admin"
                        type="object"
                />
                <button name="open_revert_wizard"
                        class="btn-outline-warning"
                        string="Reddi Geri Al"
                        confirm="Are you sure you want to revert the request?"
                        attrs="{'invisible': [('can_be_revert','=',False)]}"
                        type="object"
                />
                <field name="can_be_revert" invisible="1"/>
                <button name="reject_tier"
                        string="Reject"
                        attrs="{'invisible': [('can_review', '=', False)]}"
                        type="object"
                        class="btn-icon standard-refuse"
                        icon="fa-thumbs-down"/>
                <button name="restart_validation"
                        class="btn-warning"
                        string="Cancel Request"
                        confirm="Are you sure you want to cancel the request?"
                        attrs="{'invisible': ['|','|',('review_ids', '=', []),('state','not in',['in_validation']),('is_creator','=',False)]}"
                        type="object"
                />
            </header>
            <header position="after">
                <field name="need_validation" groups="base.group_no_one"/>
                <field name="validated" groups="base.group_no_one"/>
                <field name="rejected" groups="base.group_no_one"/>
                <field name="is_creator" groups="base.group_no_one"/>
                <field name="can_review" invisible="1"/>
                <div class="alert alert-success"
                     role="alert"
                     attrs="{'invisible': ['|', '|', ('validated', '!=', True), ('state', 'not in', ['in_validation','rejected','approved']), ('review_ids', '=', [])]}"
                     style="margin-bottom:0px;">
                    <p>
                        <i class="fa fa-thumbs-up"/>
                        Operation has been <b>validated</b>!
                    </p>
                </div>
                <div class="alert alert-danger"
                     role="alert"
                     attrs="{'invisible': ['|', '|', ('rejected', '!=', True), ('state', 'not in', ['in_validation','rejected','approved']), ('review_ids', '=', [])]}"
                     style="margin-bottom:0px;">
                    <p>
                        <i class="fa fa-thumbs-down"/>
                        Operation has been <b>rejected</b>.
                    </p>
                </div>
            </header>
            <sheet position="inside">
                <field name="review_ids" widget="tier_validation"
                       attrs="{'invisible':[('review_ids', '=', [])]}"/>
                <field name="review_history" widget="tier_history"
                       attrs="{'invisible':[('review_ids', '=', [])]}"/>
            </sheet>
        </field>
    </record>

    <record id="zone_auth_request_filter" model="ir.ui.view">
        <field name="name">Card auth Request Search</field>
        <field name="model">hr.attendance.card.auth.request</field>
        <field name="arch" type="xml">
            <search string="Search Request">
                <field name="record_num"/>
                <field name="zone_id"/>
                <field name="reason"/>
                <field name="state"/>
                <field name="create_uid"/>
                <field name="create_date"/>
                <field name="write_date"/>
                <filter name="needs_review" string="Needs my Review"
                        domain="[('reviewer_ids','in',uid), ('state', 'not in', ['approved', 'rejected','draft'])]"
                        help="My requests to review"/>
            </search>
        </field>
    </record>

    <record id="no_edit_in_approved_state_base" model="ir.rule">
        <field name="name">No Edit in validation, approve or reject state</field>
        <field name="model_id" ref="model_hr_attendance_card_auth_request"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="domain_force">[('state', '!=', 'in_validation'),('state', '!=', 'approved'),('state', '!=',
            'rejected'),('create_uid','=',user.id)]
        </field>
    </record>

