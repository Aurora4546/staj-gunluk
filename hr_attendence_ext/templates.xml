<odoo>
    <data>

        <record id="email_template_zone_auth_assignment" model="mail.template">
            <field name="name">Authorization System</field>
            <field name="model_id" ref="hr_attendance_ext.model_hr_attendance_card_auth_request"/>
            <field name="subject">Tesis Güvenlik - Bölge Giriş Yetki Talebi Onaylanmıştır</field>
            <field name="email_from">${object.env['ir.config_parameter'].sudo().get_param('Huma_mail') | safe}</field>
            <!--            Tier Validation Mailinde CC olarak gidenlere şimdi TO olarak gidecek-->
            <field name="email_to">${object.get_email_cc()}</field>
            <field name="email_cc">${object.get_emails_of_people_to_notify()}</field>
            <field name="body_html" type="html">
                <div>a</div>
            </field>
            <field name="user_signature" eval="False"/>
            <field name="auto_delete" eval="False"/>
        </record>


    </data>
</odoo>