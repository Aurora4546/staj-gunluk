<odoo>
    <data>
        <record id="hr_attendance_movement_type_view" model="ir.ui.view">
            <field name="name">Movement Types</field>
            <field name="model">resource.move_type</field>
            <field name="arch" type="xml">
                <tree create="false" editable="top" delete="false">
                    <field name="name" readonly="1"/>
                    <field name="char_code" readonly="1"/>
                    <field name="integration" />
                    <field name="move_direction" />
                    <field name="counter_move" />
                    <field name="is_trace" />
                    <field name="code" readonly="1"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>