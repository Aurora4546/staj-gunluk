        <record id="card_auth_request_group_base_rule" model="ir.rule">
            <field name="name">Can see group card authorize request</field>
            <field name="model_id" ref="model_hr_attendance_card_auth_request"/>
            <field eval="False" name="perm_unlink"/>
            <field eval="False" name="perm_write"/>
            <field eval="True" name="perm_read"/>
            <field eval="False" name="perm_create"/>
            <field name="domain_force">
                ['|','|','|',('reviewer_ids','in',user.ids),('requester.user_id', '=', user.id),
                ('requester.department_id','child_of',user.employee_ids[-1].managed_departments.ids if
                user.employee_ids
                else
                [0]),('requester.department_id','child_of',user.employee_ids[:1].assistant_manager_dept_ids.ids)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="card_auth_request_group_manager_rule" model="ir.rule">
            <field name="name">Can see group card authorize request manager</field>
            <field name="model_id" ref="model_hr_attendance_card_auth_request"/>
            <field name="domain_force">
                [(1, '=', 1)]
            </field>
            <field name="groups"
                   eval="[(4, ref('hr_attendance_ext.group_attendance_one')),(4, ref('hr_attendance_ext.group_attendance_four'))]"/>
        </record>

        <record id="card_auth_request_group_two_rule" model="ir.rule">
            <field name="name">Can see group card authorize request owner</field>
            <field name="model_id" ref="model_hr_attendance_card_auth_request"/>
            <field name="domain_force">['|','|',('create_uid','=',user.id),('zone_auth_owner.user_id', 'child_of',
                user.id),('reviewer_ids','in',user.id)]
            </field>
            <field name="groups" eval="[(4, ref('hr_attendance_ext.group_attendance_two'))]"/>
        </record>

