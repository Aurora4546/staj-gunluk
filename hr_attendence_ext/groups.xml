        <record id="card_authorization_group_three_rule" model="ir.rule">
            <field name="name">Can see group three authorize</field>
            <field name="model_id" ref="model_hr_attendance_card_authorization"/>
            <field eval="False" name="perm_unlink"/>
            <field eval="False" name="perm_write"/>
            <field eval="True" name="perm_read"/>
            <field eval="False" name="perm_create"/>
            <field name="domain_force">
                [(1, '=', 1)]
            </field>
            <field name="groups" eval="[(4, ref('hr_attendance_ext.group_attendance_three'))]"/>
        </record>

        <record id="card_authorization_group_five_move_rule" model="ir.rule">
            <field name="name">Can see group five moves</field>
            <field name="model_id" ref="model_hr_attendance_move"/>
            <field eval="False" name="perm_unlink"/>
            <field eval="False" name="perm_write"/>
            <field eval="True" name="perm_read"/>
            <field eval="False" name="perm_create"/>
            <field name="domain_force">
