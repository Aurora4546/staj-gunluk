<odoo>

    <record id="hr_employee_history_inherit_view" model="ir.ui.view">
        <field name="name">Employee History Inherit</field>
        <field name="model">hr.employee.history</field>
        <field name="inherit_id" ref="hr_employee_history.view_employee_history_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='movement_type']" position="after">
                <field name="is_authorize_removed" attrs="{'invisible': [('movement_type','not in',['3', '5'])]}"/>
            </xpath>

        </field>
    </record>


</odoo>