<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="card_confirmation_wizard" model="ir.ui.view">
        <field name="name">Kart Oluşturma Onay Ekranı</field>
        <field name="model">attendance.card.confirmation.wizard</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
             <form string="Onay Ekranı">

                 <group class="align-middle">
                    <div style="width:100%;">Okuttuğunuz kart sistemde kayıtlı değildir. Geçici kart veriyorsanız öncelikle kartın sistemde kayıtlı olması gerekmektedir.</div>
                    <div style="width:100%;"><field name="is_temporary" nolabel="1" style="color:red;"/> Okutulan kart geçici kart değildir.</div>
                 </group>
                 <footer>
                     <button name="confirm_card_creation"
                             string="Yeni Kart Oluştur" type="object"
                             class="btn btn-success" attrs="{'invisible': [('is_temporary', '=', 'False')]}"/>
                     <button special="cancel" string="İptal" class="oe_link"/>
                 </footer>
            </form>
        </field>
    </record>

</odoo>