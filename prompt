        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>


    <record id="approval_standard_model_name_tree" model='ir.ui.view'>
        <field name="name">approval_standard.model.name.tree</field>
