<odoo>
    <data>
        <record id="evaluation_result_wizard_view" model="ir.ui.view">
            <field name="name">Performans Değerlendirme Raporu</field>
            <field name="model">hr_performance.evaluation_result</field>
            <field name="groups_id" eval="[(4,ref('hr_performance.group_hr_performance_one'))]"/>
            <field name="arch" type="xml">
                <form string="Performans Değerlendirme Raporu">
                    <sheet>
                        <group>
                            <field name="employee_image" widget="image" opitons="{'size' : [50, 60]}"
                                   string=" "
                                   readonly="1"
                                   attrs="{'invisible':[('employee_id','=',False)],'readonly':[('readonly_flag','=',True)]}"/>
                            <field name="employee_id" string="Çalışan" attrs="{'readonly':[('readonly_flag','=',True)]}"
                                   options="{'no_create': True,'no_open': True,'no_quick_create':True,'no_create_edit':True}"/>
                            <field name="employee_personel_id" readonly="1"
                                   attrs="{'invisible':[('employee_id','=',False)]}"/>
                            <field name="employee_department_id" readonly="1"
                                   attrs="{'invisible':[('employee_id','=',False)]}"
                                   options="{'no_create': True,'no_open': True,'no_quick_create':True,'no_create_edit':True}"/>
                            <field name="year" domain="[('evaluation_results_report_open','=',True)]"
                                   options="{'no_create': True,'no_open': True,'no_quick_create':True,'no_create_edit':True}"/>
                            <field name="readonly_flag" invisible="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_apply"
                                string="Performans Değerlendirme Raporu"
                                class="btn btn-outline-info"
                                type="object"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_evaluation_result_wizard">
            <field name="name">Performans Değerlendirme Raporu</field>
            <field name="res_model">hr_performance.evaluation_result</field>
            <field name="view_mode">form</field>
            <field name="domain">[]</field>
            <field name="groups_id" eval="[(4,ref('hr_performance.group_hr_performance_one'))]"/>
            <field name="context">{
                }
            </field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
