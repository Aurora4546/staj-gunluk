    def write(self, vals):
        calendar_1 = self.env["ir.config_parameter"].sudo().get_param("hr_shift_plan.calendar_1") or "-1"
        calendar_2 = self.env["ir.config_parameter"].sudo().get_param("hr_shift_plan.calendar_2") or "-1"
        calendar_3 = self.env["ir.config_parameter"].sudo().get_param("hr_shift_plan.calendar_3") or "-1"
        for s in self:
            new_shift = s.shift_type
            new_calendar_id = str(s.calendar_id.id)
            if 'shift_type' in vals:
                new_shift = vals['shift_type']
            if 'calendar_id' in vals:
                new_calendar_id = str(vals['calendar_id'])

            new_date_from = s.date_from
            new_date_to = s.date_to

            change_dates = False
            if 'date_from' in vals:
                new_date_from = datetime.strptime(vals['date_from'], '%Y-%m-%d').date()
                change_dates = True
            if 'date_to' in vals:
                new_date_to = datetime.strptime(vals['date_to'], '%Y-%m-%d').date()
                change_dates = True

            search_matrix = self.env['hr.shift_plan_matrix_temp'].search(
                [('employee_id', '=', s.employee_id.id)]).filtered(
                lambda x: s.date_from <= x.plan_date.date() <= s.date_to)

            new_search_matrix = self.env['hr.shift_plan_matrix_temp'].search(
                [('employee_id', '=', s.employee_id.id)]).filtered(
                lambda x: new_date_from <= x.plan_date.date() <= new_date_to)

            if search_matrix:
                search_matrix.write({'shift_type': False})

            if new_calendar_id == calendar_1:
                calendar = 1
            elif new_calendar_id == calendar_2:
                calendar = 2
            elif new_calendar_id == calendar_3:
                calendar = 3
            else:
                calendar = ''

            new_shift_type = new_shift + str(calendar)

            if new_search_matrix:
                new_search_matrix.write({'shift_type': new_shift_type})

            if 'active' in vals and not vals['active']:
                rewrite_matrix = self.env['hr.shift_plan_matrix_temp'].search(
                    [('employee_id', '=', s.employee_id.id)]).filtered(
                    lambda x: s.date_from <= x.plan_date.date() <= s.date_to)
                rewrite_matrix.write({'shift_type': False})
            if 'active' in vals and vals['active'] and not s.active:
                raise UserError(
                    _('You cannot open the archive record.'))
            if change_dates:
                s.recalculate_changed_shift(new_date_from, new_date_to)
        vals.update({'up_number': 0})
        res = super(HrShiftPlan, self).write(vals)
        for i in self:
            active = vals.get('active', i.active)
            if active:
                i.check_ed_learning(i)
                if not self.env.context.get('no_up_db2', False):
                    i.update_db2_the_shift(is_delete=False)
            else:
                i.update_db2_the_shift(is_delete=True)
        return res

    @api.model
    def create_matrix_list(self, plan):
        matrix = []
        if type(plan['date_from']) == str:
            plan_date = datetime.strptime(plan['date_from'], '%Y-%m-%d')
        else:
            plan_date = datetime.strptime(plan['date_from'].strftime('%Y-%m-%d'), '%Y-%m-%d')

        if type(plan['date_to']) == str:
            plan_to = datetime.strptime(plan['date_to'], '%Y-%m-%d')
        else:
            plan_to = datetime.strptime(plan['date_to'].strftime('%Y-%m-%d'), '%Y-%m-%d')
        year = plan_date.year
        start = datetime(int(year), int(plan_date.month), 1)
        end = datetime(int(year), int(plan_date.month), monthrange(year, plan_date.month)[1])
        search_matrix = self.env['hr.shift_plan_matrix_temp'].search(
            [('employee_id', '=', plan['employee_id'])]).filtered(
            lambda x: start <= x.plan_date <= end).sorted(key=lambda r: r.plan_date, reverse=False)

        calendar_1 = self.env["ir.config_parameter"].sudo().get_param("hr_shift_plan.calendar_1") or "-1"
        calendar_2 = self.env["ir.config_parameter"].sudo().get_param("hr_shift_plan.calendar_2") or "-1"
        calendar_3 = self.env["ir.config_parameter"].sudo().get_param("hr_shift_plan.calendar_3") or "-1"

        if str(plan['calendar_id']) == str(calendar_1):
            calendar = 1
        if str(plan['calendar_id']) == str(calendar_2):
            calendar = 2
        if str(plan['calendar_id']) == str(calendar_3):
            calendar = 3

        if not search_matrix:
            [matrix.append({
                'employee_id': plan['employee_id'],
                'plan_date': str(single_date),
                'shift_type': plan['shift_type'] + str(calendar) if plan_date <= datetime.strptime(
                    single_date.strftime('%Y-%m-%d'), '%Y-%m-%d') <= plan_to else None
            }) for single_date in (start.date() + timedelta(n) for n in range(monthrange(year, plan_date.month)[1]))]
        else:
            change = search_matrix.filtered(
                lambda x: plan_date <= x.plan_date <= plan_to)
            change.write({'shift_type': plan['shift_type'] + str(calendar)})

        if matrix:
            self.env['hr.shift_plan_matrix_temp'].create(matrix)

