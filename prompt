        conn = ibm_db.connect(
            "DATABASE=LNXUDBP;HOSTNAME=Taivts1;PORT=50001;PROTOCOL=TCPIP;UID={};PWD={};".format(user, password), "", "")

        sql = """SELECT ID, TRIM(IS_MERKEZI) AS IS_MERKEZI, TRIM(DESCRIPTION) AS DESCRIPTION, TRIM(DEPT_HOME) AS DEPT_HOME FROM ERP2.KAPASITE 
                         WHERE IS_MERKEZI_TIP_ID ='2' AND DEPT_HOME NOT LIKE '999%' AND AKTIF_PASIF = 1 WITH UR"""
        stmt = ibm_db.prepare(conn, sql)

        ibm_db.execute(stmt)
        capacity = []

        row = ibm_db.fetch_both(stmt)
        while row:
            capacity.append({'task_center': row.get('IS_MERKEZI').strip(),
                             'dept_home':row.get('DEPT_HOME', "").strip(),'description':row.get('DESCRIPTION', "").strip() })
            row = ibm_db.fetch_both(stmt)

        return capacity

    def update_task_center_from_legacy(self):
        data_dict_list = self.update_task_center_from_legacy_new()

        created_list = []
        for data in data_dict_list:
            is_task_center_exist = self.search_count(
                [('active', '=', True), ('task_center', '=', data.get('task_center'))])
