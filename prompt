    @api.depends('employee_id', 'date_from', 'date_to')
    def calc_calculation_type_dynamically(self):
        for i in self:
            employee_id = i.employee_id
            if employee_id and i.date_from and i.date_to:
                mid_date = i.date_from + timedelta(days=(i.date_to - i.date_from).days / 2)
                config_dict = employee_id.sudo().get_attendance_config_at_time(mid_date, True)
                attendances = config_dict[employee_id.id][0].filtered(
                    lambda x: x.dayofweek == str(mid_date.weekday()))
                if attendances:
                    i.calendar_id_cmp = attendances[0].calendar_id.id
                else:
                    i.calendar_id_cmp = False
            else:
                i.calendar_id_cmp = False

