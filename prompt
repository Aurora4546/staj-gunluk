        calculate_attendance_summary_process(self.env, self.employee_id, date_range)

    @api.constrains('calendar_id', 'date_from', 'date_to')
    def check_shift_cover(self):
        calendar_ids = self.env["ir.config_parameter"].sudo().get_param("hr_shift_plan.default_calendar_id","-1").split(',')
        for i in self:
            if str(i.calendar_id.id) in calendar_ids:
                times_to_iterate = 1
                new_calender_array = []

                infinite_data = cycle(calendar_ids)

                for element in islice(infinite_data, len(calendar_ids) * times_to_iterate):
                    new_calender_array.append(element)

                current_from_control = self.env['hr.shift_plan'].sudo().search(
                    [('employee_id', '=', i.employee_id.id), (
                        'date_to', '=', i.date_from - timedelta(days=1))])

                current_to_control = self.env['hr.shift_plan'].sudo().search(
                    [('employee_id', '=', i.employee_id.id), (
                        'date_from', '=', i.date_to + timedelta(days=1))])

                if calendar_ids.index(str(i.calendar_id.id)) + 1 == len(new_calender_array):
                    calendar_to_control = False
                else:
                    calendar_to_control = new_calender_array[calendar_ids.index(str(i.calendar_id.id)) + 1]

                if calendar_ids.index(str(i.calendar_id.id)) == 0:
                    calendar_from_control = False
                else:
                    calendar_from_control = new_calender_array[calendar_ids.index(str(i.calendar_id.id)) - 1]

                if current_from_control and current_from_control.calendar_id.id == int(calendar_from_control):
                    raise UserError(
                        'Birbirini takip eden günlerde oluşturulan vardiya planları V2-V3 sırasıyla yapılmamalıdır.{}'.format(
                            str(i.employee_id.sudo().personel_id)))

                if current_to_control and current_to_control.calendar_id.id == int(calendar_to_control):
                    raise UserError(
                        'Birbirini takip eden günlerde oluşturulan vardiya planları V2-V3 sırasıyla yapılmamalıdır.{}'.format(
                            str(i.employee_id.sudo().personel_id)))

