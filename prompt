    @api.multi
    def get_shift_information(self, inputDate, employeeId):

        origin_date = inputDate
        returnDic = {}
        resource_lunck_obj = self.env['resource.lunch.break'].sudo()
        employee = self.env['hr.employee'].sudo().browse(employeeId)
        cur_calendar_id = employee.sudo().get_attendance_config_at_time(origin_date, True)

        is_version = employee.get_emp_version(origin_date)
        if is_version:
            calculation_type = is_version.calendar_id.calculation_type
        else:
            calculation_type = employee.resource_calendar_id.calculation_type

        if calculation_type == 'weekly':
            return {}

        shiftPlan = self.search(
            [('employee_id', '=', employeeId), ('date_from', '<=', inputDate), ('date_to', '>=', inputDate)], limit=1)
        if shiftPlan:
            returnDic['calendar_id'] = shiftPlan.calendar_id
            returnDic['lunch_break_id'] = resource_lunck_obj.search([('calendar_id', '=', returnDic['calendar_id'].id)])
            returnDic['shift_type'] = shiftPlan.shift_type
            whichDay = (inputDate - shiftPlan.date_from).days + 1
            returnDic['whichDay'] = whichDay
            if shiftPlan.shift_type == 'R':
                if whichDay == 7:
                    returnDic['weekend'] = 1
                if whichDay == 8:
                    returnDic['weekend'] = 2
            else:
                if not shiftPlan._compute_flexible_shift(inputDate):
                    weekDayNo = inputDate.weekday()
                    if weekDayNo == 5:
                        returnDic['weekend'] = 1
                    if weekDayNo == 6:
                        returnDic['weekend'] = 2
        else:
            delta = relativedelta(days=-1)
            inputDate = inputDate + delta
            shiftPlan = self.search(
                [('employee_id', '=', employeeId), ('date_from', '<=', inputDate), ('date_to', '>=', inputDate)],
                limit=1)
            if shiftPlan and not self.search([('employee_id', '=', employeeId)], limit=1)._compute_flexible_shift(
                    origin_date):
                returnDic['calendar_id'] = shiftPlan.calendar_id
                returnDic['lunch_break_id'] = resource_lunck_obj.search(
                    [('calendar_id', '=', returnDic['calendar_id'].id)])
                returnDic['shift_type'] = shiftPlan.shift_type
                if shiftPlan.shift_type == 'R':
                    if (shiftPlan.date_to - shiftPlan.date_from).days + 1 == 6:
                        returnDic['weekend'] = 1
                    else:
                        returnDic['weekend'] = 2
                    returnDic['calendar_id'] = cur_calendar_id[employee.id][2]
                    returnDic['lunch_break_id'] = employee.sudo().lunch_break_id
                else:
                    return {}

            elif self.search([('employee_id', '=', employeeId)], limit=1)._compute_flexible_shift(
                    origin_date) and origin_date.weekday() in (5, 6):
                returnDic['calendar_id'] = cur_calendar_id[employee.id][2] if employee.id in cur_calendar_id else -1
                returnDic['lunch_break_id'] = employee.sudo().lunch_break_id
                returnDic['shift_type'] = shiftPlan.shift_type
                if origin_date.weekday() == 5:
                    returnDic['weekend'] = 1
                if origin_date.weekday() == 6:
                    returnDic['weekend'] = 2
            elif shiftPlan and self.search([('employee_id', '=', employeeId)], limit=1)._compute_flexible_shift(
                    origin_date):
                shiftPlan2 = self.search(
                    [('employee_id', '=', employeeId), ('date_from', '<=', inputDate + relativedelta(days=+2)),
                     ('date_to', '>=', inputDate + relativedelta(days=+2))],
                    limit=1)
                returnDic['calendar_id'] = cur_calendar_id[employee.id][2]
                returnDic['lunch_break_id'] = employee.sudo().lunch_break_id
                returnDic['shift_type'] = shiftPlan.shift_type
                if shiftPlan2:
                    returnDic['weekend'] = 2
                else:
                    returnDic['weekend'] = 1
            else:
                if not self.search([('employee_id', '=', employeeId)], limit=1)._compute_flexible_shift(origin_date):
                    delta = relativedelta(days=-1)
                    inputDate = inputDate + delta
                    shiftPlan = self.search(
                        [('employee_id', '=', employeeId), ('date_from', '<=', inputDate),
                         ('date_to', '>=', inputDate)],
                        limit=1)
                    if shiftPlan:
                        returnDic['calendar_id'] = shiftPlan.calendar_id
                        returnDic['lunch_break_id'] = resource_lunck_obj.search(
                            [('calendar_id', '=', returnDic['calendar_id'].id)])
                        returnDic['shift_type'] = shiftPlan.shift_type
                        if shiftPlan.shift_type == 'R':
                            returnDic['weekend'] = 2
                            if employee.id in cur_calendar_id:
                                returnDic['calendar_id'] = cur_calendar_id[employee.id][2]
                            returnDic['lunch_break_id'] = employee.sudo().lunch_break_id
                        else:
                            return {}
                else:
                    delta = relativedelta(days=+2)
                    inputDate = inputDate + delta
                    shiftPlan = self.search(
                        [('employee_id', '=', employeeId), ('date_from', '<=', inputDate),
                         ('date_to', '>=', inputDate)],
                        limit=1)
                    if shiftPlan:
                        returnDic['calendar_id'] = cur_calendar_id[employee.id][2]
                        returnDic['lunch_break_id'] = employee.sudo().lunch_break_id
                        returnDic['shift_type'] = shiftPlan.shift_type
                        returnDic['weekend'] = 2
        return returnDic

